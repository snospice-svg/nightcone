---
const { active } = Astro.props;
const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/#matrix', label: 'The Matrix', key: 'matrix' },
  { href: '/#experiments', label: 'Experiments', key: 'experiments' },
  { href: '/journal/', label: 'Journal', key: 'journal' },
  { href: '/faq/', label: 'FAQ', key: 'faq' },
  { href: '/contact/', label: 'Contact', key: 'contact' },
];
---
<header class="site-head">
  <div class="wrap">
    <a class="brand" href="/">
      <img class="brand-logo" src="/assets/nightcone_rectangular_logo.png" alt="Nightcone Labs" style="height:40px;width:auto;display:block;mix-blend-mode:multiply" />
    </a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
    <nav class="main">
      {links.map((l) => (
        <a href={l.href} class={active === l.key ? 'active' : undefined}>{l.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  (function () {
    var btn = document.querySelector('.nav-toggle');
    var head = document.querySelector('.site-head');
    if (!btn || !head) return;
    btn.addEventListener('click', function () {
      var open = head.classList.toggle('nav-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  })();
</script>
